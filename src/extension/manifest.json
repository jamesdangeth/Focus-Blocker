{
  "manifest_version": 3,
  "name": "AI Focus Blocker \u2013 Stop Distractions & Boost Productivity",
  "version": "1.0.0",
  "description": "AI-powered focus coach for intentional web browsing.",
  "permissions": [
    "storage",
    "tabs",
    "commands",
    "alarms",
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}